# =============================================================================
# CompanyVerse Backend — environment configuration template
# Copy to .env, fill in the secrets, and never commit .env to source control.
# All non-secret values shown are the working defaults.
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=CompanyVerse Backend
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# DATA & OUTPUT PATHS
# Relative paths are resolved against the backend/ directory.
# =============================================================================
DATA_DIR=../org_data
GENERATED_DIR=generated

# =============================================================================
# PROVIDER SELECTION — flip any seam with a single line, zero code changes
# =============================================================================

# Knowledge source for org data + document retrieval
#   local   → reads synthetic CSV/markdown from DATA_DIR  (default, no creds)
#   foundry → Foundry IQ Azure AI Search knowledge base   (needs SEARCH_* vars)
PROVIDER=local

# Generative AI — writes all quest/NPC/dialogue/challenge prose
#   local        → deterministic offline engine  (default, no creds)
#   foundry      → Azure AI Foundry model        (needs AZURE_OPENAI_* vars)
#   azure_openai → standard Azure OpenAI         (needs AZURE_OPENAI_* vars)
LLM_PROVIDER=local

# Organizational graph (Work IQ seam)
#   local  → derived from synthetic dataset  (default)
#   workiq → Microsoft Work IQ               (scaffold; connect a tenant to enable)
ORG_GRAPH=local

# =============================================================================
# WORLD GENERATION
# =============================================================================
WORLD_NAME=CompanyVerse
WORLD_SEED=1337
AUTO_GENERATE_ON_STARTUP=true
MAX_QUESTS_PER_BUNDLE=5

# =============================================================================
# GENERATIVE AI — Azure AI Foundry / Azure OpenAI
# Required when LLM_PROVIDER=foundry or azure_openai.
# =============================================================================

# Model endpoint.  The /openai/v1 suffix selects the v1 (OpenAI-compatible)
# surface; without it the classic Azure OpenAI surface is used.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/openai/v1

# Exact deployment name as shown in the Foundry / Azure OpenAI portal.
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# API version — only used by the classic (non-v1) Azure surface.
AZURE_OPENAI_API_VERSION=2024-10-21

# API key for the Azure OpenAI / Foundry resource.
# Falls back to FOUNDRY_API_KEY if this is not set.
AZURE_OPENAI_API_KEY=

# Set to true to use DefaultAzureCredential (az login / managed identity)
# instead of an API key.
AZURE_OPENAI_USE_AAD=false

# =============================================================================
# FOUNDRY IQ — Azure AI Search knowledge base
# Required when PROVIDER=foundry.
# =============================================================================

# Azure AI Foundry project endpoint.
PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# Shared API key for the Foundry / Azure OpenAI resource.
# Also used as a fallback for AZURE_OPENAI_API_KEY.
FOUNDRY_API_KEY=

# Foundry project name.
FOUNDRY_PROJECT=<your-project-name>

# Azure AI Search service endpoint (the one connected to the Foundry project).
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net

# Knowledge base name as shown in Foundry portal → Knowledge tab.
FOUNDRY_INDEX=<your-knowledge-base-name>

# Azure AI Search query key — Azure portal → Search service → Keys → Query keys.
# Falls back to FOUNDRY_API_KEY if not set.
# Leave empty to use DefaultAzureCredential (for RBAC-only search services).
SEARCH_API_KEY=

# =============================================================================
# SSL  (Windows / Python 3.14 only)
# Uncomment if you see SSL certificate errors with the Foundry IQ search client.
# Not needed on Linux/macOS or managed cloud deployments.
# =============================================================================
# SSL_CERT_FILE=.venv/Lib/site-packages/certifi/cacert.pem
