# CompanyVerse backend configuration
# Copy to .env and adjust as needed. All values shown are defaults.

# --- Application ---
APP_NAME=CompanyVerse Backend
ENVIRONMENT=development
DEBUG=true

# --- Knowledge provider ---
# local  -> synthetic dataset in DATA_DIR (default, Milestone 1)
# foundry -> Foundry IQ (Milestone 5 scaffold)
# Switching this requires no code changes.
PROVIDER=local

# --- Data + output locations ---
# Relative paths are resolved against the backend/ directory.
DATA_DIR=../org_data
GENERATED_DIR=generated

# --- World generation ---
WORLD_NAME=CompanyVerse
WORLD_SEED=1337
AUTO_GENERATE_ON_STARTUP=true

# --- Foundry IQ (Milestone 5 — leave blank for local development) ---
FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_PROJECT=
FOUNDRY_INDEX=
