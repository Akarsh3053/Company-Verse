# CompanyVerse backend configuration
# Copy to .env and adjust as needed. All values shown are defaults.

# --- Application ---
APP_NAME=CompanyVerse Backend
ENVIRONMENT=development
DEBUG=true

# --- Knowledge provider ---
# local  -> synthetic dataset in DATA_DIR (default)
# foundry -> Foundry IQ retrieval (scaffold)
# Switching this requires no code changes.
PROVIDER=local

# --- Generative AI provider (who writes quests/dialogue/challenges) ---
# local        -> offline deterministic engine (no credentials needed)
# azure_openai / foundry -> real Azure OpenAI / Foundry chat model
LLM_PROVIDER=foundry

# --- Data + output locations ---
# Relative paths are resolved against the backend/ directory.
DATA_DIR=../org_data
GENERATED_DIR=generated

# --- World generation ---
WORLD_NAME=CompanyVerse
WORLD_SEED=1337
AUTO_GENERATE_ON_STARTUP=true


PROJECT_ENDPOINT=
FOUNDRY_API_KEY=
# Live host for this resource is *.services.ai.azure.com (the *.openai.azure.com
# host 404s for this account). Classic Azure OpenAI route: the SDK appends
# /openai/deployments/<deployment>/chat/completions?api-version=...
AZURE_OPENAI_ENDPOINT=
FOUNDRY_PROJECT=


#Deploy one in the Foundry portal and set its EXACT name here; generation
# switches to real AI automatically (offline engine is the per-call fallback).
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2025-08-07
